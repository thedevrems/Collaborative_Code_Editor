# Server runtime
NODE_ENV=development
PORT=4000

# Front-end origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# Redis connection (volatile room state)
REDIS_URL=redis://localhost:6379

# PostgreSQL connection (session persistence)
DATABASE_URL=postgres://editor:editor@localhost:5432/editor

# Execution sandbox resource quotas per run
EXEC_CPUS=0.5
EXEC_MEMORY=128m
EXEC_PIDS=64
EXEC_TIMEOUT_MS=5000
